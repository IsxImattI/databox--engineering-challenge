{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.Extensions.Http": "Warning",
      "DataboxConnector": "Information"
    }
  },
  "Databox": {
    "BaseUrl": "https://api.databox.com",
    "DataSourceTitle": "Databox Connector Demo",
    "IdentifierStorePath": "data/databox-identifiers.json"
  },
  "Sources": {
    "GitHub": {
      "BaseUrl": "https://api.github.com",
      "Repositories": [],
      "UserAgent": "DataboxConnector/1.0",
      "DefaultLookbackDays": 30,
      "MaxItemsPerRun": 5000,
      "IncludeCommitStats": false
    },
    "Spotify": {
      "ApiBaseUrl": "https://api.spotify.com",
      "AccountsBaseUrl": "https://accounts.spotify.com",
      "RedirectUri": "http://127.0.0.1:8888/callback",
      "TokenStorePath": "data/spotify-tokens.json",
      "DefaultLookbackDays": 7,
      "TopTrackTimeRanges": [ "short_term", "medium_term", "long_term" ],
      "TopTracksLimit": 20
    }
  }
}